# Postgres (read-only creds provided in exploration/db_connection.txt)
DATABASE_URL=postgresql://developer:REPLACE_ME@34.79.32.228:5432/candidate_profiles

# OpenRouter API key (see exploration/openrouter.txt)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Storage paths (relative to repo root is fine)
CHROMA_PERSIST_PATH=./data/chroma

# Models
LLM_MODEL=anthropic/claude-haiku-4.5
EMBEDDING_MODEL=openai/text-embedding-3-small

# Reasoning model — used for Parser + Judge (1 LLM call each per query).
# Keep LLM_MODEL cheap for RAG rerank (≤50 calls); spend here on quality.
REASONING_MODEL=openai/gpt-5.4-20260305
REASONING_EFFORT=medium

# Retrieval
HYDE_ENABLED=true
RAG_TOP_K=50
DETERMINISTIC_TOP_K=5
FINAL_TOP_K=5

# Ingestion cap — set to 200 for fast dev cycles; remove / set empty for full 10k run.
INGEST_LIMIT=200
